# MINDDRIFT frontend (Expo) – example environment file.
#
# Copy this file to `.env` and adjust the values for your local setup:
#
#   cp .env.example .env
#
# IMPORTANT:
# - Only variables prefixed with EXPO_PUBLIC_ are exposed to the app at
#   runtime. They are bundled with the JS, so NEVER put real secrets here.
# - The actual `.env` file is git-ignored and must never be committed.

# Base URL of the MINDDRIFT backend API.
# Examples:
#   https://minddrift-backend-876469026451.europe-west1.run.app  (deployed Cloud Run backend, default fallback)
#   http://localhost:8080            (Android/iOS simulator on the same machine)
#   http://192.168.1.42:8080         (physical device on the same Wi-Fi)
#   https://api.your-domain.example  (other deployed backend)
EXPO_PUBLIC_API_URL=https://minddrift-backend-876469026451.europe-west1.run.app
